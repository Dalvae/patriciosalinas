---
import Layout from "../../layouts/Layout.astro";
import { getCollection, getEntry, type CollectionEntry } from "astro:content";
import type { Lang } from "../../types/types";
import ProseContent from "../../components/ProseContent.astro";
import HomePage from "../../components/HomePage.astro";
import GalleryPage from "../../components/GalleryPage.astro";
import PressPage from "../../components/PressPage.astro";
import VideosPage from "../../components/VideosPage.astro";

type PageEntry = CollectionEntry<"pages">;
type ProjectEntry = CollectionEntry<"projects">;

export async function getStaticPaths() {
  function parseUri(uri: string): string | undefined {
    return uri === "/" || /^\/(en|es|sv)\/$/.test(uri)
      ? undefined
      : uri.replace(/^\/(en|es|sv)\//, "").replace(/\/$/, "");
  }

  const [pages, projects] = await Promise.all([
    getCollection("pages"),
    getCollection("projects"),
  ]);

  const pagesByLang: Record<string, typeof pages> = {};
  for (const page of pages) (pagesByLang[page.data.lang] ??= []).push(page);

  const pagePaths = pages.map((page) => ({
    params: { lang: page.data.lang, uri: parseUri(page.data.uri) },
    props: { pages: pagesByLang[page.data.lang] ?? [], entry: page, kind: "page" as const },
  }));

  const projectPaths = projects.map((project) => ({
    params: { lang: project.data.lang, uri: parseUri(project.data.uri) },
    props: { pages: pagesByLang[project.data.lang] ?? [], entry: project, kind: "project" as const },
  }));

  return [...pagePaths, ...projectPaths];
}

const { entry, pages, kind } = Astro.props as {
  entry: PageEntry | ProjectEntry;
  pages: PageEntry[];
  kind: "page" | "project";
};

const lang = entry.data.lang as Lang;

if (!entry) {
  return Astro.redirect("/404");
}

const type = kind === "project" ? "project" : (entry as PageEntry).data.type;

// Single-entry lookups via getEntry (O(1)) instead of getCollection + find (O(n))
const home = type === "home" ? await getEntry("home", lang) : null;
const gallery = type === "gallery" ? await getEntry("gallery", "gallery") : null;
const press = type === "press" ? await getEntry("press", lang) : null;
const videos = type === "videos" ? await getEntry("videos", "videos") : null;
const allProjects = await getCollection("projects");
---

<Layout title={entry.data.title} lang={lang} pages={pages} projects={allProjects}>
  {
    type === "home" && home ? (
      <HomePage home={home} lang={lang} />
    ) : type === "gallery" && gallery ? (
      <GalleryPage gallery={gallery} pageTitle={entry.data.title} lang={lang} />
    ) : type === "press" && press ? (
      <PressPage press={press} pageTitle={entry.data.title} />
    ) : type === "videos" && videos ? (
      <VideosPage videos={videos} lang={lang} pageTitle={entry.data.title} />
    ) : (
      <ProseContent entry={entry} title={entry.data.title} images={entry.data.images.map(img => ({ src: img.src, alt: img.alt, caption: img.caption }))} />
    )
  }
</Layout>
