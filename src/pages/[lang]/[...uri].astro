---
import Layout from "../../layouts/Layout.astro";
import { getCollection, getEntry } from "astro:content";
import type { Lang } from "../../types/types";
import ProseContent from "../../components/ProseContent.astro";
import HomePage from "../../components/HomePage.astro";
import GalleryPage from "../../components/GalleryPage.astro";
import PressPage from "../../components/PressPage.astro";
import VideosPage from "../../components/VideosPage.astro";

export async function getStaticPaths() {
  const pages = await getCollection("pages");

  // Pre-group by language — single pass instead of O(n²) filtering inside map
  const pagesByLang: Record<string, typeof pages> = {};
  for (const entry of pages) {
    (pagesByLang[entry.data.lang] ??= []).push(entry);
  }

  return pages.map((page) => {
    const lang = page.data.lang;
    const langPages = pagesByLang[lang] ?? [];

    const projects = langPages
      .filter((entry) => entry.data.type === "project")
      .sort((a, b) => a.data.order - b.data.order)
      .map((entry) => ({
        key: entry.data.translationKey,
        title: entry.data.title,
        uri: entry.data.uri,
        // Images from frontmatter — populated by export script, no runtime parsing
        images: (entry.data.images ?? []).map((img) => img.src),
      }));

    return {
      params: {
        lang,
        uri: page.data.uri === "/" || /^\/(en|es|sv)\/$/.test(page.data.uri)
          ? undefined
          : page.data.uri.replace(/^\/(en|es|sv)\//, "").replace(/\/$/, ""),
      },
      props: {
        pages: langPages,
        page,
        projects,
      },
    };
  });
}

const { page, pages, projects } = Astro.props;
const lang = page.data.lang as Lang;

if (!page) {
  return Astro.redirect("/404");
}

const type = page.data.type;
// Single-entry lookups via getEntry (O(1)) instead of getCollection + find (O(n))
const home = type === "home" ? await getEntry("home", lang) : null;
const gallery = type === "gallery" ? await getEntry("gallery", "gallery") : null;
const press = type === "press" ? await getEntry("press", lang) : null;
const videos = type === "videos" ? await getEntry("videos", "videos") : null;
---

<Layout title={page.data.title} lang={lang} pages={pages}>
  {
    type === "home" && home ? (
      <HomePage home={home} projects={projects} lang={lang} />
    ) : type === "gallery" && gallery ? (
      <GalleryPage gallery={gallery} pageTitle={page.data.title} lang={lang} />
    ) : type === "press" && press ? (
      <PressPage press={press} pageTitle={page.data.title} />
    ) : type === "videos" && videos ? (
      <VideosPage videos={videos} lang={lang} pageTitle={page.data.title} />
    ) : (
      <ProseContent entry={page} title={page.data.title} />
    )
  }
</Layout>
