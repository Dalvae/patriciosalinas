---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "../types/types";
import { useTranslations } from "../i18n/utils";

type ProjectEntry = CollectionEntry<"projects">;

interface Props {
  projects: ProjectEntry[];
  pageTitle: string;
  lang: Lang;
}

const { projects, pageTitle, lang } = Astro.props;
const t = useTranslations(lang);

const sortedProjects = [...projects].sort((a, b) => b.data.order - a.data.order);

function stripInline(text: string) {
  return text
    .replace(/import\s+.+?;?\n/g, "")
    .replace(/<[^>]*>/g, " ")
    .replace(/:::[\s\S]*?:::/g, " ")
    .replace(/!\[[^\]]*\]\([^)]+\)/g, " ")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/[*_`#>{}]/g, "")
    .replace(/\s+/g, " ")
    .trim();
}

function excerptOf(project: ProjectEntry) {
  const body = stripInline(project.body ?? "");
  if (body.length <= 220) return body;
  return `${body.slice(0, 220).trimEnd()}...`;
}
---

<section class="page-content">
  <div class="page-shell projects-shell">
    <header class="projects-header">
      <h1>{pageTitle}</h1>
      <p>{t("nav.subtitle")}</p>
    </header>

    <div class="projects-list">
      {sortedProjects.map((project) => {
        const image = project.data.images[0];
        const excerpt = excerptOf(project);

        return (
          <article class="project-row">
            <a href={project.data.uri} class="project-thumb" aria-label={project.data.title}>
              {image && (
                <img
                  src={image.src}
                  alt={image.alt || project.data.title}
                  loading="lazy"
                  decoding="async"
                  draggable="false"
                  oncontextmenu="return false"
                />
              )}
            </a>

            <div class="project-copy">
              <h2>
                <a href={project.data.uri}>{project.data.title}</a>
              </h2>
              {excerpt && <p>{excerpt}</p>}
              <a class="project-link" href={project.data.uri}>{t("home.viewProject")}</a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .projects-shell {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .projects-header {
    max-width: 46rem;
    margin-inline: auto;
    text-align: center;
  }

  .projects-header h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 500;
    line-height: 1.15;
  }

  .projects-header p {
    margin: 0;
    color: #4b5563;
    font-size: 1rem;
    line-height: 1.5;
  }

  .projects-list {
    display: grid;
    gap: 0;
  }

  .project-row {
    display: grid;
    grid-template-columns: minmax(11rem, 18rem) minmax(0, 1fr);
    gap: clamp(1.25rem, 4vw, 3rem);
    padding-block: clamp(1.5rem, 4vw, 2.75rem);
    border-top: 1px solid #e5e7eb;
    align-items: center;
  }

  .project-row:last-child {
    border-bottom: 1px solid #e5e7eb;
  }

  .project-thumb {
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f5f5f5;
  }

  .project-thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .project-thumb:hover img,
  .project-thumb:focus-visible img {
    transform: scale(1.025);
  }

  .project-copy {
    display: grid;
    gap: 1rem;
    max-width: 48rem;
  }

  .project-copy h2 {
    margin: 0;
    font-size: clamp(1.35rem, 2.4vw, 2rem);
    font-weight: 500;
    line-height: 1.2;
  }

  .project-copy h2 a {
    color: #111111;
    text-decoration: none;
  }

  .project-copy h2 a:hover,
  .project-copy h2 a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  .project-copy p {
    margin: 0;
    color: #111111;
    font-size: 1rem;
    line-height: 1.7;
    text-align: justify;
    hyphens: auto;
  }

  .project-link {
    width: max-content;
    color: #111111;
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: 1px solid #111111;
    padding-bottom: 0.2rem;
  }

  .project-link:hover,
  .project-link:focus-visible {
    border-bottom-width: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .project-thumb img {
      transition: none;
    }
  }

  @media (max-width: 720px) {
    .project-row {
      grid-template-columns: 1fr;
    }

    .project-thumb {
      aspect-ratio: 3 / 2;
    }
  }
</style>
