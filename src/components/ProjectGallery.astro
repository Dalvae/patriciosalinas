---
import ProtectedImage from "./ui/ReactProtectedImage";

interface ImageData {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  images: ImageData[];
  columns?: number;
}

const { images, columns = 3 } = Astro.props;
const allImageUrls = images.map((img) => img.src);

const colsClass = `cols-${Math.min(columns, 3)}`;
---

{images.length > 0 && (
  <div class="project-gallery">
    <div class:list={["gallery-masonry", colsClass]}>
      {images.map((image) => (
        <figure>
          <ProtectedImage
            client:load
            src={image.src}
            alt={image.alt}
            allImages={allImageUrls}
            caption={image.caption || undefined}
          />
        </figure>
      ))}
    </div>
  </div>
)}

<style>
  .project-gallery {
    width: min(100%, 100ch);
    margin-inline: auto;
    padding-inline: 1rem;
    padding-block: clamp(2rem, 5vw, 4rem);
  }

  .gallery-masonry {
    column-gap: clamp(0.85rem, 2vw, 1.5rem);
  }

  .gallery-masonry.cols-1 {
    columns: 1;
  }

  .gallery-masonry.cols-2 {
    columns: 2;
  }

  .gallery-masonry.cols-3 {
    columns: 3;
  }

  .gallery-masonry figure {
    break-inside: avoid;
    margin: 0 0 clamp(0.85rem, 2vw, 1.5rem);
    background: #f5f5f5;
  }

  .gallery-masonry :global(.protected-image-container) {
    width: 100% !important;
    height: auto !important;
  }

  @media (max-width: 900px) {
    .gallery-masonry.cols-2,
    .gallery-masonry.cols-3 {
      columns: 2;
    }
  }

  @media (max-width: 600px) {
    .gallery-masonry {
      columns: 1 !important;
    }
  }
</style>
