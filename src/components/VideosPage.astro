---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "../types/types";

interface Props {
  videos: CollectionEntry<"videos">;
  lang: Lang;
  pageTitle?: string;
}

const { videos, lang, pageTitle } = Astro.props;
const titleFor = (video: typeof videos.data.videos[number]) =>
  video.titles?.[lang] || video.title;
---

<section class="content-wrapper">
  <div class="content-card">
    <h1 class="mb-8 text-center text-[clamp(2rem,4vw,3.5rem)] font-medium">{pageTitle || "Videos"}</h1>
    <div class="videos-grid">
      {videos.data.videos.map((video) => (
        <figure class="m-0">
          <iframe
            src={`https://www.youtube.com/embed/${video.id}`}
            title={titleFor(video)}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            class="w-full aspect-video border-0 bg-[#111]"
          />
          <figcaption class="pt-3 leading-relaxed text-center">{titleFor(video)}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .content-wrapper {
    width: 100%;
    max-width: 92rem;
    margin-inline: auto;
    padding-block: clamp(3rem, 7vw, 7rem);
    padding-inline: clamp(1rem, 4vw, 4rem);
  }

  .content-card {
    background: #fff;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .videos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: clamp(1rem, 2vw, 1.5rem);
  }
</style>

<style>
  @media (max-width: 640px) {
    .grid-cols-\[repeat\(auto-fit\,minmax\(18rem\,1fr\)\)\] {
      grid-template-columns: 1fr;
    }
  }
</style>
