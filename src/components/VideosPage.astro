---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "../types/types";

interface Props {
  videos: CollectionEntry<"videos">;
  lang: Lang;
  pageTitle?: string;
}

const { videos, lang, pageTitle } = Astro.props;
const titleFor = (video: typeof videos.data.videos[number]) =>
  video.titles?.[lang] || video.title;
---

<section class="page-content">
  <div class="page-shell">
    <h1>{pageTitle || "Videos"}</h1>
    <div class="videos-list">
      {videos.data.videos.map((video) => (
        <figure class="m-0 bg-[#111] rounded-sm overflow-hidden">
          <iframe
            src={`https://www.youtube.com/embed/${video.id}`}
            title={titleFor(video)}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            class="w-full aspect-video border-0"
          />
          <figcaption class="p-4 text-white text-lg leading-relaxed">{titleFor(video)}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .page-content {
    width: 100%;
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 4rem) clamp(1rem, 4vw, 2rem);
  }

  .page-shell {
    background: #fff;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .page-shell h1 {
    margin: 0 0 2rem;
    text-align: center;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 500;
  }

  .videos-list {
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3rem);
  }
</style>
