---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import type { Lang } from "../types/types";
import MasonryGallery from "./MasonryGallery.astro";

interface Props {
  gallery: CollectionEntry<"gallery">;
  page?: CollectionEntry<"pages">;
  pageTitle?: string;
  lang: Lang;
}

const { gallery, page, pageTitle, lang } = Astro.props;
const images = gallery.data.images.map((image) => ({
  src: image.src,
  alt: image.alt[lang],
  caption: image.title[lang].replace(/\|/g, "<br>"),
  width: image.width?.toString() ?? "auto",
  height: image.height?.toString() ?? "auto",
}));

const { Content } = page ? await render(page) : { Content: null };
---

<section class="page-content">
  <div class="page-shell">
    <h1>{pageTitle || "Gallery"}</h1>
    {Content && <div class="prose prose-lg max-w-none text-justify mb-8"><Content /></div>}
    <MasonryGallery images={images} columns={gallery.data[lang]?.columns ?? 2} />
  </div>
</section>

<style>
  .prose {
    --tw-prose-body: #000;
    --tw-prose-headings: #000;
  }

  .page-content {
    width: 100%;
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 4rem) clamp(1rem, 4vw, 2rem);
  }

  .page-shell {
    background: #fff;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .page-shell h1 {
    margin: 0 0 2rem;
    text-align: center;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 500;
  }
</style>
