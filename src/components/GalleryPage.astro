---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "../types/types";
import ProjectGallery from "./ProjectGallery.astro";

interface Props {
  gallery: CollectionEntry<"gallery">;
  pageTitle?: string;
  lang: Lang;
}

const { gallery, pageTitle, lang } = Astro.props;
const images = gallery.data.images.map((image) => ({
  src: image.src,
  alt: image.alt[lang],
  caption: image.title[lang].replace(/\|/g, "<br>"),
  width: image.width?.toString() ?? "auto",
  height: image.height?.toString() ?? "auto",
}));
---

<section class="content-wrapper">
  <div class="content-card">
    <h1 class="mb-8 text-center text-[clamp(2rem,4vw,3.5rem)] font-medium">{pageTitle || "Gallery"}</h1>
    <ProjectGallery images={images} />
  </div>
</section>

<style>
  .content-wrapper {
    width: 100%;
    max-width: 92rem;
    margin-inline: auto;
    padding-block: clamp(3rem, 7vw, 7rem);
    padding-inline: clamp(1rem, 4vw, 4rem);
  }

  .content-card {
    background: #fff;
    padding: clamp(1rem, 3vw, 2rem);
  }
</style>
