---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "../types/types";
import ProtectedImage from "./ui/ReactProtectedImage";

interface Props {
  gallery: CollectionEntry<"gallery">;
  pageTitle?: string;
  lang: Lang;
}

const { gallery, pageTitle, lang } = Astro.props;
const images = gallery.data.images.map((image) => ({
  src: image.src,
  alt: image.alt[lang] || Object.values(image.alt)[0] || "",
  caption: (image.title[lang] || Object.values(image.title)[0] || "").replace(/\|/g, "<br>"),
}));
const allImageUrls = gallery.data.images.map((img) => img.src);
---

<section class="gallery-page">
  <div class="gallery-shell">
    <h1>{pageTitle || "Gallery"}</h1>
    <div class="gallery-grid">
      {images.map((image) => (
        <figure>
          <ProtectedImage
            client:load
            src={image.src}
            alt={image.alt}
            allImages={allImageUrls}
            caption={image.caption}
          />
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery-page {
    width: min(100%, 92rem);
    margin-inline: auto;
    padding-block: clamp(3rem, 7vw, 7rem);
    padding-inline: clamp(1rem, 4vw, 4rem);
  }

  .gallery-shell {
    background: #fff;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .gallery-shell h1 {
    margin: 0 0 2rem;
    text-align: center;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 500;
  }

  .gallery-grid {
    columns: 3;
    column-gap: clamp(0.85rem, 2vw, 1.5rem);
  }

  .gallery-grid figure {
    break-inside: avoid;
    margin: 0 0 clamp(0.85rem, 2vw, 1.5rem);
    background: #f5f5f5;
  }

  .gallery-grid :global(.protected-image-container) {
    width: 100% !important;
    height: auto !important;
  }

  @media (max-width: 900px) {
    .gallery-grid {
      columns: 2;
    }
  }

  @media (max-width: 600px) {
    .gallery-grid {
      columns: 1;
    }
  }
</style>
