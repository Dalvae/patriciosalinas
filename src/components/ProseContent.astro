---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import ProjectGallery from "./ProjectGallery.astro";

interface ImageData {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  entry?: CollectionEntry<"pages"> | CollectionEntry<"projects">;
  title?: string;
  images?: ImageData[];
}

const { entry, title, images = [] } = Astro.props;
const { Content } = entry ? await render(entry) : { Content: null };
---

{Content && (
  <div class="page-content">
    <div class="page-shell">
      <article class="prose prose-lg max-w-none text-justify hyphens-auto mx-auto text-black w-full max-w-[72ch]">
        {title && <h1 class="text-center font-semibold py-5 !text-[clamp(2rem,4vw,3.5rem)]">{title}</h1>}
        <Content />
      </article>
    </div>
  </div>
)}

<ProjectGallery images={images} />

<style>
  /* Force full black on all prose text */
  .prose {
    --tw-prose-body: #000;
    --tw-prose-headings: #000;
    --tw-prose-bold: #000;
  }

  /* Keep only what Tailwind prose doesn't cover */
  .prose :where(h1, h2, h3) {
    font-family: "Playfair Display", serif;
  }

  .prose img {
    width: 100%;
    max-width: 100%;
    height: auto;
  }

  .page-content {
    width: min(100%, 92rem);
    margin-inline: auto;
    padding-block: clamp(3rem, 7vw, 7rem);
    padding-inline: clamp(1rem, 4vw, 4rem);
  }

  .page-shell {
    background: #fff;
    padding: clamp(1rem, 3vw, 2rem);
  }
</style>
