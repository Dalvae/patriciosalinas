---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry?: CollectionEntry<"pages">;
  title?: string;
}

const { entry, title } = Astro.props;
const { Content } = entry ? await render(entry) : { Content: null };
---

{Content && (
  <article class="prose prose-lg max-w-none text-justify hyphens-auto mx-auto text-black" style="width: min(100%, 72ch)">
    {title && <h1 class="text-center font-semibold py-5 !text-[clamp(2rem,4vw,3.5rem)]">{title}</h1>}
    <Content />
  </article>
)}

<style>
  /* Force full black on all prose text */
  .prose {
    --tw-prose-body: #000;
    --tw-prose-headings: #000;
    --tw-prose-bold: #000;
  }

  /* Keep only what Tailwind prose doesn't cover */
  .prose :where(h1, h2, h3) {
    font-family: "Playfair Display", serif;
  }

  .prose img {
    max-width: 100%;
    height: auto;
  }

  .markdown-gallery {
    display: grid;
    gap: 1rem;
    margin-block: 2.5rem;
  }

  .markdown-gallery.columns-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .markdown-gallery.columns-3,
  .markdown-gallery.columns-default {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .markdown-video iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
  }

  @media (max-width: 760px) {
    .markdown-gallery.columns-2,
    .markdown-gallery.columns-3,
    .markdown-gallery.columns-default {
      grid-template-columns: 1fr;
    }
  }
</style>
