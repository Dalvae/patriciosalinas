---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import ProtectedImage from "./ui/ReactProtectedImage";

interface ImageData {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  entry?: CollectionEntry<"pages"> | CollectionEntry<"projects">;
  title?: string;
  images?: ImageData[];
}

const { entry, title, images = [] } = Astro.props;
const { Content } = entry ? await render(entry) : { Content: null };
const allImageSrcs = images.map(img => img.src);
---

{Content && (
  <div class="page-content">
    <div class="page-shell">
      {images.length > 0 && (
        <div class="inline-images">
          {images.map((img) => (
            <figure>
              <ProtectedImage
                client:load
                src={img.src}
                alt={img.alt}
                allImages={allImageSrcs}
                caption={img.caption || undefined}
              />
            </figure>
          ))}
        </div>
      )}
      <article class="prose prose-lg text-justify hyphens-auto mx-auto text-black max-w-none">
        {title && <h1 class="text-center font-semibold py-5 !text-[clamp(2rem,4vw,3.5rem)]">{title}</h1>}
        <Content />
      </article>
    </div>
  </div>
)}

<style>
  .prose {
    --tw-prose-body: #000;
    --tw-prose-headings: #000;
    --tw-prose-bold: #000;
  }

  .prose :where(h1, h2, h3) {
    font-family: "Playfair Display", serif;
  }

  .prose img {
    max-width: 100%;
    height: auto;
  }

  .image-row {
    display: grid;
    gap: clamp(0.75rem, 2vw, 1.5rem);
    margin-block: clamp(1.5rem, 4vw, 2.5rem);
  }

  .image-row.cols-2 {
    grid-template-columns: 1fr 1fr;
  }

  .image-row.cols-3 {
    grid-template-columns: 1fr 1fr 1fr;
  }

  @media (max-width: 640px) {
    .image-row.cols-2,
    .image-row.cols-3 {
      grid-template-columns: 1fr;
    }
  }
</style>
