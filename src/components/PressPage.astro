---
import type { CollectionEntry } from "astro:content";
import ProtectedImage from "./ui/ReactProtectedImage";

interface Props {
  press: CollectionEntry<"press">;
  pageTitle?: string;
}

const { press, pageTitle } = Astro.props;
const { links, cards } = press.data;
const cardImages = cards.map((card) => ({
  src: card.image.src,
  alt: card.image.alt,
  caption: card.text,
}));
---

<section class="w-full max-w-[92rem] mx-auto py-[clamp(3rem,7vw,7rem)] px-[clamp(1rem,4vw,4rem)]">
  <div class="bg-white p-[clamp(1rem,3vw,2rem)]">
    <h1 class="mb-8 text-center text-[clamp(2rem,4vw,3.5rem)] font-medium">{pageTitle || "Press"}</h1>

    {links.length > 0 && (
      <div class="prose mb-12">
        <ul class="mb-0 ml-6">
          {links.map((link) => (
            <li class="mb-3 last:mb-0 leading-relaxed">
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="text-black underline underline-offset-2">
                {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {cards.length > 0 && (
      <div class="grid grid-cols-[repeat(auto-fit,minmax(18rem,1fr))] gap-[clamp(1rem,2vw,1.5rem)]">
        {cards.map((card) => (
          card.url ? (
            <a
              href={card.url}
              class="color-inherit no-underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              <article class="h-full border border-[#d4d4d4] bg-white">
                <ProtectedImage
                  client:load
                  src={card.image.src}
                  alt={card.image.alt}
                  allImages={cardImages}
                  caption={card.text}
                  containerClassName="w-full"
                />
                <p class="m-0 p-4 leading-relaxed text-left">{card.text}</p>
              </article>
            </a>
          ) : (
            <article class="h-full border border-[#d4d4d4] bg-white">
              <ProtectedImage
                client:load
                src={card.image.src}
                alt={card.image.alt}
                allImages={cardImages}
                caption={card.text}
                containerClassName="w-full"
              />
              <p class="m-0 p-4 leading-relaxed text-left">{card.text}</p>
            </article>
          )
        ))}
      </div>
    )}
  </div>
</section>

<style>
  @media (max-width: 640px) {
    .grid-cols-\[repeat\(auto-fit\,minmax\(18rem\,1fr\)\)\] {
      grid-template-columns: 1fr;
    }
  }
</style>
