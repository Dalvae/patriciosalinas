---
import type { CollectionEntry } from "astro:content";
import ProtectedImage from "./ui/ReactProtectedImage";

interface Props {
  press: CollectionEntry<"press">;
  pageTitle?: string;
}

const { press, pageTitle } = Astro.props;
const { links, cards } = press.data;
const cardImages = cards.map((card) => ({
  src: card.image.src,
  alt: card.image.alt,
  caption: card.text,
}));
---

<section class="press-page">
  <div class="press-shell">
    <h1>{pageTitle || "Press"}</h1>

    {links.length > 0 && (
      <div class="press-links prose">
        <ul>
          {links.map((link) => (
            <li>
              <a href={link.url} target="_blank" rel="noopener noreferrer">
                {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {cards.length > 0 && (
      <div class="press-grid">
        {cards.map((card) => (
          <a
            href={card.url}
            class="press-card-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            <article class="press-card">
              <ProtectedImage
                client:load
                src={card.image.src}
                alt={card.image.alt}
                allImages={cardImages}
                caption={card.text}
                containerClassName="press-card-media"
              />
              <p>{card.text}</p>
            </article>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .press-page {
    width: min(100%, 92rem);
    margin-inline: auto;
    padding-block: clamp(3rem, 7vw, 7rem);
    padding-inline: clamp(1rem, 4vw, 4rem);
  }

  .press-shell {
    background: #fff;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .press-shell h1 {
    margin: 0 0 2rem;
    text-align: center;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 500;
  }

  .press-links ul {
    padding-left: 1.5rem;
    margin-block: 1rem 3rem;
  }

  .press-links li {
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .press-links a {
    color: #111;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .press-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .press-card-link {
    color: inherit;
    text-decoration: none;
  }

  .press-card {
    height: 100%;
    border: 1px solid #d4d4d4;
    background: #fff;
  }

  .press-card-media {
    width: 100% !important;
  }

  .press-card p {
    margin: 0;
    padding: 1rem;
    line-height: 1.6;
    text-align: left;
  }

  @media (max-width: 640px) {
    .press-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
