---
import type { CollectionEntry } from "astro:content";
import ProtectedImage from "./ui/ReactProtectedImage";

interface Props {
  press: CollectionEntry<"press">;
  pageTitle?: string;
}

const { press, pageTitle } = Astro.props;
const { links, cards } = press.data;
const cardImages = cards.map((card) => ({
  src: card.image.src,
  alt: card.image.alt,
  caption: card.text,
}));
---

<section class="page-content">
  <div class="page-shell">
    <h1>{pageTitle || "Press"}</h1>

    {links.length > 0 && (
      <div class="prose mb-12">
        <ul class="mb-0 ml-6">
          {links.map((link) => (
            <li class="mb-3 last:mb-0 leading-relaxed">
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="text-black underline underline-offset-2">
                {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {cards.length > 0 && (
      <div class="press-grid">
        {cards.map((card) => (
          card.url ? (
            <a
              href={card.url}
              class="color-inherit no-underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              <article class="h-full border border-[#d4d4d4] bg-white">
                <ProtectedImage
                  client:load
                  src={card.image.src}
                  alt={card.image.alt}
                  allImages={cardImages}
                  caption={card.text}
                  containerClassName="w-full"
                />
                <p class="m-0 p-4 leading-relaxed text-left">{card.text}</p>
              </article>
            </a>
          ) : (
            <article class="h-full border border-[#d4d4d4] bg-white">
              <ProtectedImage
                client:load
                src={card.image.src}
                alt={card.image.alt}
                allImages={cardImages}
                caption={card.text}
                containerClassName="w-full"
              />
              <p class="m-0 p-4 leading-relaxed text-left">{card.text}</p>
            </article>
          )
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .page-content {
    width: 100%;
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 4rem) clamp(1rem, 4vw, 2rem);
  }

  .page-shell {
    background: #fff;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .page-shell h1 {
    margin: 0 0 2rem;
    text-align: center;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 500;
  }

  .press-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  @media (max-width: 640px) {
    .press-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
